# Shared HLF auth DB — User identity, signed-in via @hlf/auth-db.
AUTH_DATABASE_URL=postgresql://...

# Must be identical across all HLF apps for cross-app JWT validity.
NEXTAUTH_SECRET=...

# Drives sharedCookieConfig() — must start with https:// in prod for the
# cross-subdomain session cookie to be issued.
NEXTAUTH_URL=https://portal.hlfinancialstrategies.com

# Bearer token guarding /api/internal/v1/* on each consumer app. Must match
# what wheel-strat-tracker, bookkeeping, budget-tracker, and stock-alerts use.
INTERNAL_API_KEY=...

# Per-app base URLs the portal calls server-side to fetch its KPI bundle.
# In dev these point at localhost ports; in prod they point at the subdomains.
WHEEL_TRACKER_URL=https://wheel.hlfinancialstrategies.com
BOOKKEEPING_URL=https://bookkeeping.hlfinancialstrategies.com
BUDGET_TRACKER_URL=https://budget.hlfinancialstrategies.com
STOCK_ALERTS_URL=https://alerts.hlfinancialstrategies.com

# Browser-side links shown in the app launcher. Usually the same as the
# *_URL values above; broken out so dev can point them anywhere.
NEXT_PUBLIC_WHEEL_TRACKER_URL=https://wheel.hlfinancialstrategies.com
NEXT_PUBLIC_BOOKKEEPING_URL=https://bookkeeping.hlfinancialstrategies.com
NEXT_PUBLIC_BUDGET_TRACKER_URL=https://budget.hlfinancialstrategies.com
NEXT_PUBLIC_STOCK_ALERTS_URL=https://alerts.hlfinancialstrategies.com
