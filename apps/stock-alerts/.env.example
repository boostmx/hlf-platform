# Per-app local DB (own Railway). Holds Ticker/PriceBar/Subscription/Alert/UserPosition/UserPreferences.
DATABASE_URL=postgresql://...

# Shared HLF auth DB — User identity, signed-in via @hlf/auth-db.
AUTH_DATABASE_URL=postgresql://...

# Must be identical across all HLF apps.
NEXTAUTH_SECRET=...

# Used by sharedCookieConfig() — must start with https:// in prod for cross-subdomain cookie.
NEXTAUTH_URL=https://alerts.hlfinancialstrategies.com

# Internal API to wheel-strat-tracker for open-position alerts.
INTERNAL_API_KEY=...
WHEEL_TRACKER_URL=https://wheel.hlfinancialstrategies.com

# Alpaca market data
ALPACA_API_KEY=...
ALPACA_SECRET_KEY=...
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# Anthropic Claude (alert message generation)
ANTHROPIC_API_KEY=...

# Email
RESEND_API_KEY=...
RESEND_FROM_EMAIL=alerts@hlfinancialstrategies.com

# Cron (intentionally unused for now — will re-enable after batch refactor)
# CRON_SECRET=...
