generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User identity lives in the shared auth DB (@hlf/auth-db). userId here is
// an opaque string referencing User.id in that DB; no FK constraint.

// ─── App-specific user preferences ────────────────────────────────────────────
// Per-user notification + threshold settings for stock alerts. Keyed by the
// canonical auth-DB userId. Created on first read with sensible defaults.

model UserPreferences {
  userId              String   @id
  emailEnabled        Boolean  @default(true)
  discordWebhook      String?
  thresholds          Json?    // { rsiOversold, rsiOverbought, volumeMultiplier, ... }
  watchedPortfolioIds Json?    // string[] of wheel portfolio IDs to scan
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ─── Tickers ──────────────────────────────────────────────────────────────────

model Ticker {
  id            String         @id @default(cuid())
  symbol        String         @unique
  name          String
  sector        String?
  isApproved    Boolean        @default(false)
  lastPrice     Float?
  lastUpdated   DateTime?
  createdBy     String?        // auth-DB userId; opaque, no FK
  priceBars     PriceBar[]
  subscriptions Subscription[]
  alerts        Alert[]
  positions     UserPosition[]
  hiddenBy      HiddenTicker[]
  createdAt     DateTime       @default(now())

  @@index([createdBy])
}

model HiddenTicker {
  userId   String
  tickerId String
  ticker   Ticker @relation(fields: [tickerId], references: [id], onDelete: Cascade)

  @@id([userId, tickerId])
  @@index([userId])
}

model PriceBar {
  id       String   @id @default(cuid())
  tickerId String
  date     DateTime @db.Date
  open     Float
  high     Float
  low      Float
  close    Float
  volume   BigInt
  ticker   Ticker   @relation(fields: [tickerId], references: [id], onDelete: Cascade)

  @@unique([tickerId, date])
  @@index([tickerId, date])
}

model Subscription {
  id               String   @id @default(cuid())
  userId           String
  tickerId         String
  customThresholds Json?
  ticker           Ticker   @relation(fields: [tickerId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())

  @@unique([userId, tickerId])
  @@index([userId])
}

model Alert {
  id       String    @id @default(cuid())
  userId   String
  tickerId String
  type     AlertType
  signals  Json
  message  String
  sentAt   DateTime  @default(now())
  channel  String
  ticker   Ticker    @relation(fields: [tickerId], references: [id], onDelete: Cascade)

  @@index([userId, sentAt])
}

enum AlertType {
  CSP_OPPORTUNITY
  CC_OPPORTUNITY
  SUPPORT_BREAK
  RESISTANCE_BREAK
  VOLUME_SURGE
  SMA_CROSS_UP
  SMA_CROSS_DOWN
  PROFIT_TARGET
  ASSIGNMENT_RISK
  ROLL_OPPORTUNITY
}

enum PositionType {
  CSP
  CC
  STOCK
}

model UserPosition {
  id             String       @id @default(cuid())
  userId         String
  tickerId       String
  positionType   PositionType
  contracts      Int          @default(1)
  strikePrice    Float?
  premium        Float?
  shares         Int?
  entryPrice     Float?
  expirationDate DateTime?
  notes          String?
  openedAt       DateTime     @default(now())
  closedAt       DateTime?
  ticker         Ticker       @relation(fields: [tickerId], references: [id], onDelete: Cascade)

  @@index([userId, tickerId])
  @@index([userId, closedAt])
}
