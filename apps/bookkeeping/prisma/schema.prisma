generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User identity lives in the shared auth DB (@hlf/auth-db). userId here is
// an opaque string referencing User.id in that DB; no FK constraint.

// ─── Bookkeeping ──────────────────────────────────────────────────────────────

model BookkeepingEntry {
  id          String      @id @default(cuid())
  userId      String
  type        EntryType
  name        String?
  category    String
  amount      Decimal     @db.Decimal(18, 2)
  description String?
  date        DateTime
  source      EntrySource @default(manual)
  recurring   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId, date])
  @@index([userId, type, date])
}

enum EntryType {
  income
  expense
}

enum EntrySource {
  manual
  trading
}

model BookkeepingMonthNote {
  id        String   @id @default(cuid())
  userId    String
  yearMonth String   // "YYYY-MM"
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, yearMonth])
  @@index([userId])
}

// `tradingPortfolios` lived here until 2026-05-16 — moved to
// @hlf/auth-db's `User.tradingPortfolios` as a shared per-user setting
// (one source of truth across portal + bookkeeping). This row is kept
// for future per-app bookkeeping preferences; today it only stores
// `userId` and `updatedAt`.
model BookkeepingSettings {
  userId    String   @id
  updatedAt DateTime @updatedAt
}
